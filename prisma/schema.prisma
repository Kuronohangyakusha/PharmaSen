generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Utilisateur {
  id           String     @id @default(uuid())
  nom          String
  email        String     @unique
  motDePasse   String
  role         Role       @default(VISITEUR)
  estActif     Boolean    @default(true)
  dateCreation DateTime   @default(now())
  dateMaj      DateTime   @updatedAt
  pharmacie    Pharmacie?
}

model Pharmacie {
  id             String      @id @default(uuid())
  nom            String
  adresse        String
  quartier       String
  telephone      String
  latitude       Float
  longitude      Float
  horaires       String
  estValidee     Boolean     @default(false)
  dateCreation   DateTime    @default(now())
  dateMaj        DateTime    @updatedAt
  proprietaireId String      @unique
  estOuverte     Boolean     @default(true)
  gardes         Garde[]
  proprietaire   Utilisateur @relation(fields: [proprietaireId], references: [id], onDelete: Cascade)
  stocks         Stock[]
}

model Medicament {
  id            String   @id @default(uuid())
  nomCommercial String
  nomGenerique  String
  description   String?
  categorie     String
  dateCreation  DateTime @default(now())
  dateMaj       DateTime @updatedAt
  stocks        Stock[]
}

model Stock {
  id            String     @id @default(uuid())
  quantite      Int        @default(0)
  prix          Float
  estDisponible Boolean    @default(true)
  dateMaj       DateTime   @updatedAt
  pharmacieId   String
  medicamentId  String
  medicament    Medicament @relation(fields: [medicamentId], references: [id], onDelete: Cascade)
  pharmacie     Pharmacie  @relation(fields: [pharmacieId], references: [id], onDelete: Cascade)

  @@unique([pharmacieId, medicamentId])
}

model Garde {
  id          String    @id @default(uuid())
  dateDebut   DateTime
  dateFin     DateTime
  typeGarde   TypeGarde @default(JOUR)
  pharmacieId String
  pharmacie   Pharmacie @relation(fields: [pharmacieId], references: [id], onDelete: Cascade)
}

enum Role {
  VISITEUR
  PHARMACIEN
  ADMIN
}

enum TypeGarde {
  JOUR
  NUIT
}
